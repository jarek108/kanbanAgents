{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "name": "ensure-vibe-kanban",
            "type": "command",
            "command": "cmd.exe /c start_board.bat"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "vibe-kanban": {
      "command": "node",
      "args": [
        "../vibe-kanban/npx-cli/bin/cli.js",
        "mcp"
      ],
      "env": {
        "HOST": "127.0.0.1",
        "PORT": "61154"
      }
    }
  }
}
